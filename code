# 7.  Figure 5 — Theorem 1 bound vs. observed error (MLP, INT8)
# ─────────────────────────────────────────────────────────────────────────────

def plot_bound_vs_observed() -> str:
    """
    Figure 5 — Grouped bar chart comparing the deterministic bound
    (Theorem 1) against the observed relative error for each MLP layer
    at INT8 precision.

    Key finding: the bound is uniformly valid (never below the observed
    value) with a tightness ratio rho ~ 182 at the output; the
    probabilistic refinement (Theorem 2) reduces this to rho_prob ~ 8
    (Section 5.5, Table 5 of the report).
    """
    layers   = BOUND_VS_OBS["layers"]
    observed = BOUND_VS_OBS["observed"]
    det_bnd  = BOUND_VS_OBS["det_bound"]
    x        = np.arange(len(layers))
    w        = 0.35

    fig, ax = plt.subplots(figsize=(6.8, 4.6))

    b1 = ax.bar(x - w / 2, observed, w, label="Observed error",
                color="#4a7abc", edgecolor="black", zorder=3)
    b2 = ax.bar(x + w / 2, det_bnd,  w, label="Theorem 1 bound",
                color="#e74c3c", edgecolor="black", alpha=0.85, zorder=3)

    ax.set_yscale("log")
    ax.set_ylim(1e-4, 5e-1)
    ax.set_xticks(x)
    ax.set_xticklabels(layers, fontsize=11)
    ax.set_xlabel("MLP layer", fontsize=11)
    ax.set_ylabel("Relative error  (log scale)", fontsize=11)
    ax.grid(True, axis="y", linestyle="--", alpha=0.5, zorder=0)

    # Annotate bars
    for bar, val in zip(b1, observed):
        ax.text(bar.get_x() + bar.get_width() / 2,
                val * 1.5, f"{val:.2e}",
                ha="center", va="bottom", fontsize=7.5, color="#1a1a2e")
    for bar, val in zip(b2, det_bnd):
        ax.text(bar.get_x() + bar.get_width() / 2,
                val * 1.5, f"{val:.2e}",
                ha="center", va="bottom", fontsize=7.5, color="#8b0000")

    ax.set_title(
        "Figure 5 — Theorem 1 Bound vs. Observed Error  (MLP, INT8)\n"
        "Bound is uniformly valid; tightness ratio \u03c1 \u2248 182 at output",
        fontsize=11, fontweight="bold",
    )
    ax.legend(fontsize=9, loc="upper right")
    plt.tight_layout()
    return _save(fig, "fig_5_bound_vs_observed.png")



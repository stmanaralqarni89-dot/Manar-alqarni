def plot_calibration() -> tuple[str, str]:
    """
    Figure 3a & 3b — Relative quantization error vs. calibration set size N,
    log-log axes, with a dashed O(1/sqrt(N)) reference line.

    Finding: INT8 follows O(1/sqrt(N)) and saturates near N=10,000.
    INT4 plateaus immediately — calibration size is irrelevant at 4 bits
    (Section 5.3, Proposition 2 of the report).
    """
    N       = np.array(CALIB_N)
    N_dense = np.logspace(np.log10(N[0]), np.log10(N[-1]), 300)

    # ── 3a: INT8 ────────────────────────────────────────────────────────────
    fig, ax = plt.subplots(figsize=(6.8, 4.4))
    ax.plot(N, CALIB_INT8_ERR, marker="o", color="#1c7293",
            linewidth=2, markersize=6, label="INT8  measured")
    # O(1/sqrt(N)) reference scaled to first point
    c_ref = CALIB_INT8_ERR[0] * np.sqrt(N[0])
    ax.plot(N_dense, c_ref / np.sqrt(N_dense),
            linestyle="--", color="#e74c3c", linewidth=1.8,
            label=r"$O(1/\sqrt{N})$ reference")
    ax.set_xscale("log")
    ax.set_yscale("log")
    ax.set_xlabel("Calibration set size  $N$", fontsize=11)
    ax.set_ylabel("Relative quantization error", fontsize=11)
    ax.set_title("Figure 3a — PTQ Calibration Convergence (INT8)\n"
                 "Solid: measured  |  Dashed: O(1/\u221aN) reference",
                 fontsize=11, fontweight="bold")
    ax.grid(True, which="both", linestyle="--", alpha=0.4)
    ax.legend(fontsize=9)
    plt.tight_layout()
    path_a = _save(fig, "fig_3a_calibration_int8.png")

    # ── 3b: INT4 ────────────────────────────────────────────────────────────
    fig, ax = plt.subplots(figsize=(6.8, 4.4))
    ax.plot(N, CALIB_INT4_ERR, marker="s", color="#e67e22",
            linewidth=2, markersize=6, label="INT4  measured")
    c_ref4 = CALIB_INT4_ERR[0] * np.sqrt(N[0])
    ax.plot(N_dense, c_ref4 / np.sqrt(N_dense),
            linestyle="--", color="#e74c3c", linewidth=1.8,
            label=r"$O(1/\sqrt{N})$ reference")
    ax.set_xscale("log")
    ax.set_yscale("log")
    ax.set_xlabel("Calibration set size  $N$", fontsize=11)
    ax.set_ylabel("Relative quantization error", fontsize=11)
    ax.set_title("Figure 3b — PTQ Calibration Convergence (INT4)\n"
                 "Solid: measured  |  Dashed: O(1/\u221aN) reference",
                 fontsize=11, fontweight="bold")
    ax.grid(True, which="both", linestyle="--", alpha=0.4)
    ax.legend(fontsize=9)
    plt.tight_layout()
    path_b = _save(fig, "fig_3b_calibration_int4.png")

    return path_a, path_b



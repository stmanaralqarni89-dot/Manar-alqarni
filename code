def _save(fig: plt.Figure, filename: str) -> str:
    """Save figure to FIGS_DIR and return the full path."""
    path = os.path.join(FIGS_DIR, filename)
    fig.savefig(path, dpi=160, bbox_inches="tight")
    plt.close(fig)
    return path



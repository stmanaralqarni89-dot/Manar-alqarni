# 6.  Figure 4 — Mixed-precision DP solver: memory / error Pareto curve
# ─────────────────────────────────────────────────────────────────────────────

def plot_mixed_precision_pareto() -> str:
    """
    Figure 4 — Predicted total error vs. memory (KB) for the DP solver
    across budgets 30% – 100% of the all-INT16 baseline.

    Key finding: the 40% budget already captures >99% of the error reduction,
    achieving 2x compression with only +15% predicted error (Table 4, Section
    5.4 of the report).
    """
    mem   = MP_PARETO["memory_kb"]
    err   = MP_PARETO["pred_error"]
    budg  = MP_PARETO["budget_pct"]
    assn  = MP_PARETO["assignments"]

    fig, ax = plt.subplots(figsize=(7.4, 4.8))
    ax.plot(mem, err, marker="o", color="#1b3a6b", linewidth=2.5,
            markersize=8, zorder=3)

    # Label each point
    offsets = [(0, 12), (0, 12), (0, 12), (0, 12), (0, 12), (0, 12)]
    for x_val, y_val, b, a, (dx, dy) in zip(mem, err, budg, assn, offsets):
        ax.annotate(
            f"{b}\n{a}",
            xy=(x_val, y_val),
            xytext=(x_val + dx, y_val + dy * 0.05),
            fontsize=7.5,
            ha="center",
            color="#1a1a2e",
        )

    ax.set_yscale("log")
    ax.set_xlabel("Memory  (KB)", fontsize=11)
    ax.set_ylabel("Predicted total error  (log scale)", fontsize=11)
    ax.set_title(
        "Figure 4 — Mixed-Precision Memory / Error Pareto Curve\n"
        "Each point labelled with memory budget % and bit assignments (Q/K/V/O/F1/F2)",
        fontsize=11, fontweight="bold",
    )
    ax.grid(True, which="both", linestyle="--", alpha=0.4)
    plt.tight_layout()
    return _save(fig, "fig_4_mixed_precision_pareto.png")



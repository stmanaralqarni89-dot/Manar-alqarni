def plot_public_benchmarks() -> str:
    """
    Figure 6 — Extended evaluation on standard public benchmarks.

    Displays cited FP32 accuracy and INT8 accuracy-drop values for
    GLUE/SST-2 (BERT-base) and CIFAR-10 (ResNet-18).  Numbers are taken
    from published literature (see PUBLIC_BENCHMARKS data above).
    The figure explicitly marks values as literature-cited and notes
    that full validation is deferred to future work.

    Demonstrates that the Theorem 1 bounds are directly applicable to
    both architectures (Section 4.4 of the report).
    """
    benchmarks = PUBLIC_BENCHMARKS["benchmarks"]
    fp32_acc   = PUBLIC_BENCHMARKS["fp32_accuracy"]
    int8_drop  = PUBLIC_BENCHMARKS["int8_drop_pp"]
    x          = np.arange(len(benchmarks))
    w          = 0.32

    fig, axes = plt.subplots(1, 2, figsize=(12.0, 5.2))

    # ── Left: FP32 baseline accuracy ────────────────────────────────────────
    ax = axes[0]
    bars = ax.bar(x, fp32_acc, w * 2, color=["#1c7293", "#4a7abc"],
                  edgecolor="black", zorder=3)
    ax.set_ylim(85, 97)
    ax.set_xticks(x)
    ax.set_xticklabels(["GLUE/SST-2\n(BERT-base)", "CIFAR-10\n(ResNet-18)"],
                        fontsize=11)
    ax.set_ylabel("FP32 Top-1 Accuracy (%)", fontsize=11)
    ax.set_title("FP32 Baseline Accuracy\n(literature values)", fontsize=11,
                 fontweight="bold")
    ax.grid(True, axis="y", linestyle="--", alpha=0.5, zorder=0)
    for bar, val in zip(bars, fp32_acc):
        ax.text(bar.get_x() + bar.get_width() / 2, val + 0.15,
                f"{val:.1f}%", ha="center", va="bottom", fontsize=11,
                fontweight="bold")
    ax.text(0.5, -0.18, "Source: Dettmers et al. (2022); Nagel et al. (2021)",
            transform=ax.transAxes, ha="center", fontsize=8,
            color="grey", style="italic")

    # ── Right: INT8 accuracy drop ────────────────────────────────────────────
    ax = axes[1]
    bars2 = ax.bar(x, int8_drop, w * 2, color=["#e67e22", "#e74c3c"],
                   edgecolor="black", zorder=3)
    ax.set_ylim(0.0, 1.2)
    ax.set_xticks(x)
    ax.set_xticklabels(["GLUE/SST-2\n(BERT-base)", "CIFAR-10\n(ResNet-18)"],
                        fontsize=11)
    ax.set_ylabel("INT8 Accuracy Drop (percentage points)", fontsize=11)
    ax.set_title("INT8 W8A32 Accuracy Drop\n(literature values, lower is better)",
                 fontsize=11, fontweight="bold")
    ax.grid(True, axis="y", linestyle="--", alpha=0.5, zorder=0)
    ax.axhline(y=0.5, color="#999999", linestyle=":", linewidth=1.2,
               label="0.5 pp threshold")
    for bar, val in zip(bars2, int8_drop):
        ax.text(bar.get_x() + bar.get_width() / 2, val + 0.02,
                f"{val:.2f} pp", ha="center", va="bottom", fontsize=11,
                fontweight="bold")
    ax.legend(fontsize=9, loc="upper right")
    ax.text(0.5, -0.18, "Source: Xiao et al. (2023); Frantar et al. (2023)",
            transform=ax.transAxes, ha="center", fontsize=8,
            color="grey", style="italic")

    fig.suptitle(
        "Figure 6 — Extended Evaluation on Standard Public Benchmarks\n"
        "Values cited from published literature  |  "
        "Full end-to-end validation deferred to future work",
        fontsize=11, fontweight="bold", y=1.01,
    )

    # Applicability note
    fig.text(
        0.5, -0.05,
        "Theorem 1 bounds apply directly to both architectures.  "
        "BERT-base shares the B2 transformer block architecture (d_model=768, 12 heads).  "
        "ResNet residual blocks reduce to sequential matrix multiplications.",
        ha="center", fontsize=9, color="#444444", style="italic",
        wrap=True,
    )

    plt.tight_layout()
    return _save(fig, "fig_6_public_benchmarks.png")



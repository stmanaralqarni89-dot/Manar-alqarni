# 3.  Figure 1 — MLP / MNIST bit-width sweep
# ─────────────────────────────────────────────────────────────────────────────

def plot_mlp_sweep() -> str:
    """
    Figure 1 — Bar chart (log y-axis) of relative output error across
    FP32 / FP16 / INT8 / INT4, with a secondary line for top-1 accuracy.

    Confirms the theoretical O(2^-b) scaling: each additional bit halves
    the output error (Table 1, Section 5.1 of the report).
    """
    prec   = MLP_SWEEP["precisions"]
    errors = MLP_SWEEP["rel_error"]
    accs   = MLP_SWEEP["accuracy"]
    x      = np.arange(len(prec))

    fig, ax1 = plt.subplots(figsize=(7.2, 4.8))

    bars = ax1.bar(x, errors, color="#4a7abc", edgecolor="black",
                   width=0.5, zorder=3)
    ax1.set_yscale("log")
    ax1.set_ylim(1e-8, 2.0)
    ax1.set_xticks(x)
    ax1.set_xticklabels(prec, fontsize=11)
    ax1.set_xlabel("Precision format", fontsize=11)
    ax1.set_ylabel("Relative output error  (log scale)", fontsize=11)
    ax1.grid(True, axis="y", linestyle="--", alpha=0.5, zorder=0)

    # Annotate bar tops
    for bar, val in zip(bars, errors):
        if val > 1e-7:
            ax1.text(bar.get_x() + bar.get_width() / 2,
                     val * 1.8,
                     f"{val:.2e}", ha="center", va="bottom",
                     fontsize=8, color="#1a1a2e")

    # Secondary axis: accuracy line
    ax2 = ax1.twinx()
    ax2.plot(x, accs, marker="o", color="#e74c3c", linewidth=2,
             markersize=7, label="Top-1 Accuracy", zorder=4)
    ax2.set_ylim(0.85, 0.95)
    ax2.set_ylabel("Top-1 Accuracy", fontsize=11, color="#e74c3c")
    ax2.tick_params(axis="y", colors="#e74c3c")

    ax1.set_title(
        "Figure 1 — MLP / MNIST Quantization Sweep\n"
        "Bars: relative output error (log scale)  |  Line: Top-1 Accuracy",
        fontsize=11, fontweight="bold",
    )
    ax2.legend(loc="upper right", fontsize=9)
    plt.tight_layout()
    return _save(fig, "fig_1_mlp_bit_sweep.png")



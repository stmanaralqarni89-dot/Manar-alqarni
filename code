def plot_bert_sensitivity() -> str:
    """
    Figure 2 — Bar chart (log y-axis) of per-layer sensitivity score
    s^(l) = e4^(l) * kappa^(l) for the six matmul-bearing sub-layers of a
    BERT-style transformer block.

    Key finding: attention projections are ~2,167x more sensitive than FFN
    sub-layers due to high weight-matrix condition numbers (Table 3, Section
    5.2 of the report).
    """
    layers = BERT_SENSITIVITY["layers"]
    sens   = BERT_SENSITIVITY["sensitivity"]
    kappa  = BERT_SENSITIVITY["kappa"]
    x      = np.arange(len(layers))

    fig, ax1 = plt.subplots(figsize=(8.0, 4.8))

    # Colour: attention layers in teal, FFN in grey
    colors = ["#1c7293" if "W_" in l else "#95a5a6" for l in layers]
    bars   = ax1.bar(x, sens, color=colors, edgecolor="black",
                     width=0.5, zorder=3, label="Sensitivity $s^{(\\ell)}$")
    ax1.set_yscale("log")
    ax1.set_ylim(0.05, 2000)
    ax1.set_xticks(x)
    ax1.set_xticklabels(layers, fontsize=11)
    ax1.set_xlabel("Layer", fontsize=11)
    ax1.set_ylabel("Sensitivity score  $s^{(\\ell)}$  (log scale)", fontsize=11)
    ax1.grid(True, axis="y", linestyle="--", alpha=0.5, zorder=0)

    # Annotate bars
    for bar, val in zip(bars, sens):
        ax1.text(bar.get_x() + bar.get_width() / 2,
                 val * 1.6,
                 f"{val:.1f}", ha="center", va="bottom",
                 fontsize=8, color="#1a1a2e")

    # Secondary axis: condition number line
    ax2 = ax1.twinx()
    ax2.plot(x, kappa, marker="D", color="#e74c3c", linewidth=2,
             markersize=7, linestyle="--", label="Condition number $\\kappa$",
             zorder=4)
    ax2.set_yscale("log")
    ax2.set_ylim(0.5, 20000)
    ax2.set_ylabel("Condition number  $\\kappa^{(\\ell)}$  (log scale)",
                   fontsize=11, color="#e74c3c")
    ax2.tick_params(axis="y", colors="#e74c3c")

    ax1.set_title(
        "Figure 2 — Transformer Block Per-Layer Sensitivity\n"
        "Bars: sensitivity score (log)  |  Line: condition number (log)",
        fontsize=11, fontweight="bold",
    )

    lines1, labels1 = ax1.get_legend_handles_labels()
    lines2, labels2 = ax2.get_legend_handles_labels()
    ax1.legend(lines1 + lines2, labels1 + labels2, fontsize=9, loc="upper right")
    plt.tight_layout()
    return _save(fig, "fig_2_bert_sensitivity.png")


